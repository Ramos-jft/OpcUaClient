{
  "EndpointUrl": "opc.tcp://127.0.0.1:50000",
  "ApplicationName": "OpcUaClient",
  "ApplicationUri": "urn:localhost:qf:opcua-client",
  "ProductUri": "urn:qf:opcua-client",

  "Security": {
    "SecurityMode": "None",
    "SecurityPolicy": "None",
    "AutoAcceptUntrustedCertificates": true
  },

  "Session": {
    "SessionName": "Lucas-OpcUaClient-Session",
    "SessionTimeoutMs": 60000,
    "OperationTimeoutMs": 15000,
    "KeepAliveIntervalMs": 5000
  },

  "Authentication": {
    "UseAnonymousUser": true,
    "Username": "",
    "Password": ""
  },

  "Certificates": {
    "StorePath": "pki/own",
    "TrustedStorePath": "pki/trusted",
    "RejectedStorePath": "pki/rejected"
  },


  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "OpcUaClient": "Debug",
      "System": "Warning"
    }
  }
}